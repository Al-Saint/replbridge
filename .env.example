# ─── Workspace Agent (set these in Replit Secrets) ───────────────────────────
REPLBRIDGE_PROJECT_TOKEN=replace-with-a-secure-random-token
REPLBRIDGE_WORKSPACE_ROOT=/home/runner/workspace

# ─── MCP Server (set these locally) ──────────────────────────────────────────
REPLBRIDGE_AGENT_URL=https://your-replit-project-url.replit.app
