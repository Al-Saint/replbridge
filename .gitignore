# ReplBridge — do not commit these
.replbridge/snapshots/
.replbridge/trash/
.replbridge/*.local.json

# Environment variables — never commit real tokens
.env
.env.local
.env.production
.env.*.local

# Build outputs
dist/
build/
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Dependencies
node_modules/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
