{
  "name": "@replbridge/mcp-server",
  "version": "0.1.0",
  "description": "ReplBridge MCP server — connects Claude to the ReplBridge Workspace Agent running inside a Replit project.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "replbridge-mcp": "dist/index.js"
  },
  "scripts": {
