# ReplBridge MCP Server — environment variables
# Copy this to .env and fill in your values.
# Never commit .env to git.

# The public URL of the ReplBridge Workspace Agent running inside your Replit project.
# Example: https://replbridge-workspace-agent.yourusername.repl.co
REPLBRIDGE_AGENT_URL=https://your-replit-project-url.replit.app

# The Bearer token the Workspace Agent uses to authenticate requests.
# Must match REPLBRIDGE_PROJECT_TOKEN in your Replit Secrets.
REPLBRIDGE_PROJECT_TOKEN=replace-with-your-secure-token
