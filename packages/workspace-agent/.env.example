# ReplBridge Workspace Agent — set these in Replit Secrets, never in a file you commit

# A secure random token Claude must present on every request.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REPLBRIDGE_PROJECT_TOKEN=replace-with-a-secure-random-token

# Absolute path to the Replit workspace root.
# On Replit this is typically /home/runner/workspace
REPLBRIDGE_WORKSPACE_ROOT=/home/runner/workspace

# Port the agent listens on (Replit sets this automatically)
PORT=3000
